# Server
HOST=0.0.0.0
PORT=8000
RELOAD=false
LOG_LEVEL=INFO

# Security
SECRET_KEY=change-me

# Database & Storage
DATABASE_URL=sqlite:///data/chastease.db
SETUP_STORE_PATH=data/setup_sessions.json
IMAGE_VERIFICATION_DIR=data/image_verifications

# Feature Flags
ENABLE_SESSION_KILL=false
ENABLE_AUDIT_LOG_VIEW=false
AUTH_ALLOW_LOCAL_LOGIN=true
AUTH_ENABLE_CHASTER_LOGIN=true

# LLM
OPENAI_API_KEY=
AI_SESSION_READ_TOKEN=
LLM_CHAT_RETRY_ATTEMPTS=3
LLM_CHAT_TIMEOUT_CONNECT=5
LLM_CHAT_TIMEOUT_READ=45
LLM_CHAT_TIMEOUT_WRITE=20
LLM_CHAT_TIMEOUT_POOL=5
LLM_FAIL_CLOSED_REQUEST_TAG=false

# TTLock
TTL_API_BASE=https://euapi.ttlock.com
TTL_CLIENT_ID=your-ttlock-client-id
TTL_CLIENT_SECRET=your-ttlock-client-secret

# Chaster
CHASTER_API_BASE=https://api.chaster.app
CHASTER_DEVELOPER_API_BASE=https://api.chaster.app/api
CHASTER_DEVELOPER_TOKEN=your-chaster-developer-token
CHASTER_EXTENSION_SLUG=your-extension-slug
CHASTER_OAUTH_CLIENT_ID=your-oauth-client-id
CHASTER_OAUTH_CLIENT_SECRET=your-oauth-client-secret
CHASTER_OAUTH_REDIRECT_URI=https://your-domain/api/v1/auth/chaster/callback
CHASTER_OAUTH_AUTHORIZE_URL=https://sso.chaster.app/auth/realms/app/protocol/openid-connect/auth
CHASTER_OAUTH_TOKEN_URL=https://sso.chaster.app/auth/realms/app/protocol/openid-connect/token
CHASTER_OAUTH_USERINFO_URL=https://sso.chaster.app/auth/realms/app/protocol/openid-connect/userinfo
CHASTER_OAUTH_SCOPES=openid profile locks shared_locks keyholder messaging