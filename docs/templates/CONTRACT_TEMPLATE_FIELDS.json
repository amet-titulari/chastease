{
  "template_id": "chastity_contract_v1",
  "version": "1.0.1",
  "placeholder_style": "{{field_name}}",
  "required_fields": [
    "session_id",
    "setup_session_id",
    "contract_version",
    "generated_at_iso",
    "generated_by",
    "contract_start_date",
    "contract_min_end_date",
    "contract_max_end_date",
    "proposed_end_date_ai",
    "end_date_control_mode",
    "min_duration_days",
    "max_extension_per_incident_days",
    "hard_stop_enabled",
    "pause_policy",
    "daily_checkin_required",
    "inspection_frequency_policy",
    "max_openings_in_period",
    "opening_limit_period",
    "opening_window_minutes",
    "max_penalty_per_day_minutes",
    "max_penalty_per_week_minutes",
    "reward_policy",
    "penalty_policy",
    "safety_mode",
    "hard_limits_text",
    "soft_limits_text",
    "health_protocol",
    "psychogram_summary",
    "psychogram_analysis",
    "instruction_style",
    "escalation_mode",
    "experience_profile",
    "grooming_preference",
    "tone_profile",
    "integrations",
    "autonomy_mode",
    "action_execution_mode",
    "audit_enabled",
    "amendment_policy",
    "termination_policy",
    "debrief_policy",
    "sub_name",
    "user_name",
    "keyholder_name",
    "signature_date_sub",
    "signature_sub",
    "signature_date_keyholder",
    "signature_keyholder",
    "consent_required_text",
    "consent_accepted",
    "consent_text",
    "consent_accepted_at"
  ],
  "optional_fields": [
    "safeword",
    "traffic_light_words"
  ],
  "notes": [
    "Use exactly one of safeword or traffic_light_words based on safety_mode.",
    "If end date is AI-controlled and no fixed date exists, proposed_end_date_ai may be AI-decides/KI-entscheidet.",
    "All date fields should use ISO format YYYY-MM-DD."
  ]
}
